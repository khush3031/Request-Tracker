{
  "name": "request-tracker-pro",
  "version": "1.0.5",
  "description": "Advanced HTTP request tracking and analytics middleware for Node.js. Track latency, network usage, response times, and detailed metrics with flexible storage options.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/esm/middleware/index.js",
      "require": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc && npm run build:esm",
    "build:esm": "tsc --module es2020 --outDir dist/esm --declaration && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'},null,2))\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test",
    "dashboard": "cd dashboard && npm run dev",
    "example": "node examples/express-basic.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "request-tracker",
    "analytics",
    "middleware",
    "performance",
    "monitoring",
    "logging",
    "express",
    "nodejs",
    "latency",
    "metrics"
  ],
  "author": "Khushboo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/khush3031/Request-Tracker.git"
  },
  "bugs": {
    "url": "https://github.com/khush3031/Request-Tracker/issues"
  },
  "homepage": "https://github.com/khush3031/Request-Tracker#readme",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  }
}
